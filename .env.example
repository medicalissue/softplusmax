# Copy → .env and fill in.
WANDB_API_KEY=
WANDB_PROJECT=softplusmax
WANDB_ENTITY=

S3_PREFIX=s3://your-bucket/softplusmax

AWS_DEFAULT_REGION=us-west-2
AMI=ami-XXXX           # Deep Learning Base AMI (Ubuntu 22.04, NVIDIA driver)
SG=sg-XXXX
KEY=your-keypair
IAM_PROFILE=your-instance-profile

SUBNET_us_west_2a=subnet-XXXX
SUBNET_us_west_2b=subnet-XXXX
SUBNET_us_west_2c=subnet-XXXX
SUBNET_us_west_2d=subnet-XXXX

INSTANCE_TYPE=g6.xlarge
AZ=us-west-2a

REPO_URL=https://github.com/<user>/softplusmax.git
REPO_REF=main
